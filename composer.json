{
    "name": "juniyasyos/manage-unit-kerja",
    "description": "Plugin manage Unit Kerja untuk Filament (modul terpisah)",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Juniyasyos",
            "email": "juniyasyos@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0",
        "filament/filament": "^4.0",
        "bezhansalleh/filament-shield": "^4.1",
        "guava/filament-modal-relation-managers": "^2.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Juniyasyos\\ManageUnitKerja\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Juniyasyos\\ManageUnitKerja\\ManageUnitKerjaServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}